{
    "compilerOptions": {
        "target": "es2022",
        "module": "commonjs",
        "outDir": "./build",
        "rootDir": "./",
        "moduleResolution": "node",
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "declaration": true
    },
    "include": ["./src/**/*.ts", "index.ts"],
    "exclude": ["node_modules", "build"]
}
